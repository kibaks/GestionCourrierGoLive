APP_NAME="Gestion Courrier API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5174

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="Gestion Courrier"

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gestion_courrier
DB_USERNAME=root
DB_PASSWORD=

# JWT (tymon/jwt-auth) - générer avec : php artisan jwt:secret
JWT_SECRET=
JWT_TTL=60

# CORS : autoriser le front React (Vite) à appeler l'API
# config/cors.php : allowed_origins => ['http://localhost:5173', 'http://localhost:3000'],

# Secret partagé pour obtenir un JWT depuis le front (connexion Firebase/Firestore).
# Doit être identique à VITE_LARAVEL_SYNC_SECRET dans le .env du front.
# POST /api/auth/token-by-email envoie email + sync_secret pour recevoir un JWT.
LARAVEL_SYNC_SECRET=
