# Configuration Firebase (Obligatoire)
# Récupérez ces valeurs depuis la console Firebase : https://console.firebase.google.com/
# Allez dans Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=your-app-id

# Configuration Google Sign-In (Obligatoire pour la connexion Google)
# Récupérez votre Client ID depuis Google Cloud Console
# Voir CONFIGURATION_GOOGLE_SIGNIN.md pour plus de détails
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Configuration API Scanner (Optionnel)
# URL de base de l'API scanner si vous utilisez un serveur backend
VITE_SCANNER_API_BASE_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001

# API Laravel / MySQL (Stockage niveau 2)
# URL du serveur Laravel où tourne "php artisan serve" (ex: http://localhost:8000)
# IMPORTANT : utiliser l'URL Laravel (port 8000), PAS l'URL du front Vite (port 5173). Sinon → 404.
# Si défini : upload des fichiers → MySQL via l'API, pas Firebase Storage
VITE_LARAVEL_API_URL=

# Secret partagé avec l'API Laravel pour obtenir un JWT après connexion (Firebase/Firestore).
# Doit être identique à LARAVEL_SYNC_SECRET dans laravel-api/.env. Obligatoire si VITE_LARAVEL_API_URL est défini.
VITE_LARAVEL_SYNC_SECRET=

# Mode IndexedDB (Optionnel)
# Définissez à 'true' pour utiliser IndexedDB au lieu de Firebase Storage
# Voir ACTIVER_MODE_INDEXEDDB.md pour plus de détails
VITE_USE_BLOB_STORAGE=false

# Migration Firebase → MySQL (script scripts/migrate-firebase-to-mysql.ts)
# Utilisez les mêmes VITE_FIREBASE_* ci-dessus pour Firestore.
# Pour MySQL, vous pouvez copier depuis laravel-api/.env (DB_*) ou définir :
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=gestion_courrier
